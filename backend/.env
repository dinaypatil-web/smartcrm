# Server
PORT=5000

# ============================================================
# MongoDB Connection
# ============================================================
# For DEVELOPMENT (no MongoDB installed):
#   Leave as-is — the app auto-uses an in-memory database.
#
# For PRODUCTION (MongoDB Atlas - FREE):
#   1. Sign up at https://www.mongodb.com/cloud/atlas
#   2. Create a FREE M0 cluster (Mumbai region recommended)
#   3. Create a database user and whitelist your IP
#   4. Copy the connection string below:
#
# MONGODB_URI=mongodb+srv://ayurveda_admin:YOUR_PASSWORD@cluster.xxxxx.mongodb.net/ayurveda_erp?retryWrites=true&w=majority
#
# For LOCAL MongoDB:
#   MONGODB_URI=mongodb://localhost:27017/ayurveda_erp
# ============================================================
#   MONGODB_URI=mongodb://localhost:27017/ayurveda_erp

# JWT Authentication
JWT_SECRET=ayurveda_erp_jwt_secret_key_change_in_production
JWT_REFRESH_SECRET=ayurveda_erp_refresh_secret_key_change_in_production
JWT_EXPIRE=1d
JWT_REFRESH_EXPIRE=7d

# Email Configuration (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# SMS Configuration (Fast2SMS - free for India)
FAST2SMS_API_KEY=your_fast2sms_api_key

# Company Details (shown on invoices)
COMPANY_NAME=Ayurveda Clinic
COMPANY_GSTIN=
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=

FIREBASE_PROJECT_ID=smartcrm-d8cb3
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@smartcrm-d8cb3.iam.gserviceaccount.com
