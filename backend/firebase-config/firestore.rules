service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is an admin or developer
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'developer'
      );
    }

    // Server-side (firebase-admin) bypasses these rules.
    // These are only needed if you use the Firebase Client SDK in Frontend/Mobile.
    
    match /{document=**} {
      allow read, write: if false; // Secure by default
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /entities/{entityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /items/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'store');
    }

    match /purchases/{purchaseId} {
      allow read, write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'store');
    }

    match /sales/{saleId} {
      allow read, write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'store');
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.user == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.user == request.auth.uid || isAdmin());
      allow create, delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Audit logs should only be written by server
    }
  }
}
